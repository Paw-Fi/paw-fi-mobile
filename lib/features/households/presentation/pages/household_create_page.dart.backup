            ),
          ),
        ),
      ),
    );
  }

  Future<void> _createHousehold() async {
    if (!_formKey.currentState!.validate()) {
      return;
    }

    setState(() {
      _isCreating = true;
    });

    try {
      final userId = Supabase.instance.client.auth.currentUser?.id;
      if (userId == null) {
        throw Exception('User not authenticated');
      }

      final name = _nameController.text.trim();
      final emoji = _selectedEmoji; // Use selected emoji

      // Create household
      await ref.read(userHouseholdsProvider(userId).notifier).createHousehold(
            name: name,
            emoji: emoji,
          );

      // Get the created household
      final householdsAsync = ref.read(userHouseholdsProvider(userId));
      final households = householdsAsync.value ?? [];

      if (households.isEmpty) {
        throw Exception('Failed to create household');
      }

      final household = households.first;
      _createdHouseholdId = household.id;
      _householdName = household.name;

      setState(() {
        _isCreating = false;
        _isGeneratingInvite = true;
      });

      // Automatically generate invitation
      await _generateInvitation(household.id, household.name);
    } catch (e) {
      setState(() {
        _isCreating = false;
      });

      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Error creating household: $e'),
            backgroundColor: Colors.red,
          ),
        );
      }
    }
  }

  Future<void> _generateInvitation(String householdId, String householdName) async {
    try {
      final repository = ref.read(householdRepositoryProvider);
      final inviteUrl = await repository.createInvite(
        householdId: householdId,
        expiresInDays: 7,
      );

      setState(() {
        _isGeneratingInvite = false;
      });

      if (mounted) {
        // Show success and share sheet
        InvitationShareSheet.show(
          context: context,
          inviteUrl: inviteUrl,
          householdName: householdName,
          onClose: () {
            // Navigate back to home after closing share sheet
            Navigator.of(context).popUntil((route) => route.isFirst);
          },
        );
      }
    } catch (e) {
      setState(() {
        _isGeneratingInvite = false;
      });

      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Household created but failed to generate invite: $e'),
            backgroundColor: Colors.orange,
          ),
        );

        // Still navigate back since household was created
        Navigator.of(context).popUntil((route) => route.isFirst);
      }
    }
  }

  /// Show emoji picker modal
  void _showEmojiPicker(BuildContext context, shadcnui.ColorScheme colorScheme) {
    showModalBottomSheet(
      context: context,
      backgroundColor: Colors.transparent,
      isScrollControlled: true,
      builder: (context) => Container(
        constraints: BoxConstraints(
          maxHeight: MediaQuery.of(context).size.height * 0.7,
        ),
        decoration: BoxDecoration(
          color: colorScheme.card,
          borderRadius: const BorderRadius.vertical(top: Radius.circular(24)),
        ),
        child: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            // Drag handle
            Container(
              margin: const EdgeInsets.only(top: 12, bottom: 8),
              width: 36,
              height: 4,
              decoration: BoxDecoration(
                color: colorScheme.border,
                borderRadius: BorderRadius.circular(2),
              ),
            ),

            // Header
            Padding(
              padding: const EdgeInsets.fromLTRB(24, 16, 24, 16),
              child: Row(
                mainAxisAlignment: MainAxisAlignment.spaceBetween,
                children: [
                  Text(
                    'Choose Household Icon',
                    style: TextStyle(
                      fontSize: 20,
                      fontWeight: FontWeight.bold,
                      color: colorScheme.foreground,
                    ),
                  ),
                  IconButton(
                    icon: Icon(Icons.close, color: colorScheme.foreground),
                    onPressed: () => Navigator.pop(context),
                  ),
                ],
              ),
            ),

            // Emoji grid
            Expanded(
              child: GridView.builder(
                padding: const EdgeInsets.symmetric(horizontal: 24, vertical: 8),
                gridDelegate: const SliverGridDelegateWithFixedCrossAxisCount(
                  crossAxisCount: 6,
                  mainAxisSpacing: 8,
                  crossAxisSpacing: 8,
                  childAspectRatio: 1,
                ),
                itemCount: _householdEmojis.length,
                itemBuilder: (context, index) {
                  final emoji = _householdEmojis[index];
                  final isSelected = emoji == _selectedEmoji;

                  return GestureDetector(
                    onTap: () {
                      setState(() {
                        _selectedEmoji = emoji;
                      });
                      Navigator.pop(context);
                    },
                    child: Container(
                      decoration: BoxDecoration(
                        color: isSelected
                            ? colorScheme.primary.withOpacity(0.15)
                            : colorScheme.muted,
                        borderRadius: BorderRadius.circular(12),
                        border: Border.all(
                          color: isSelected
                              ? colorScheme.primary
                              : colorScheme.border,
                          width: isSelected ? 2 : 1,
                        ),
                      ),
                      child: Center(
                        child: Text(
                          emoji,
                          style: const TextStyle(fontSize: 32),
                        ),
                      ),
                    ),
                  );
                },
              ),
            ),

            const SizedBox(height: 16),
          ],
        ),
      ),
    );
