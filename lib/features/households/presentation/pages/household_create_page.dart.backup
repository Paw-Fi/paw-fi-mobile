    '🏠', '🏡', '🏘️', '🏚️', '🏢', '🏬',
    '🏭', '🏗️', '🏛️', '🏰', '🏯', '🗼',
    
    // Row 3-4: Family & Relationships (12)
    '👨‍👩‍👧‍👦', '👪', '👨‍👩‍👧', '👨‍👩‍👦', '👨‍👦', '👩‍👧',
    '👨‍👧‍👦', '👩‍👦‍👦', '💑', '💏', '👫', '👬',
    
    // Row 5-6: Hearts & Love (12)
    '❤️', '💕', '💖', '💗', '💓', '💞',
    '💝', '❤️‍🔥', '💘', '💌', '💟', '♥️',
    
    // Row 7-8: Money & Finance (12)
    '💰', '💵', '💴', '💶', '💷', '💸',
    '💳', '💎', '🪙', '🏦', '📊', '📈',
    
    // Row 9-10: Food & Dining (12)
    '🍽️', '🍴', '🥄', '🍕', '🍔', '🍜',
    '☕', '🍷', '🥗', '🍳', '🥘', '🍰',
    
    // Row 11-12: Home & Comfort (12)
    '🛋️', '🛏️', '🚪', '🪑', '🔑', '🗝️',
    '🪟', '🧺', '🕯️', '🪴', '🖼️', '🧸',
    
    // Row 13-14: Activities & Entertainment (12)
    '🎉', '🎊', '🎈', '🎁', '🎮', '🎬',
    '📺', '🎵', '📚', '🎨', '🎯', '🎲',
    
    // Row 15-16: Nature & Garden (12)
    '🌳', '🌺', '🌻', '🌷', '🌹', '🪴',
    '🌿', '☘️', '🍀', '🌱', '🌸', '🏵️',
    
    // Row 17-18: Stars & Special (12)
    '⭐', '✨', '🌟', '💫', '🌈', '☀️',
    '🌙', '⚡', '🔥', '💥', '✴️', '🎇',
    
    // Row 19-20: Pets & Animals (12)
    '🐕', '🐈', '🐶', '🐱', '🐾', '🦮',
    '🐕‍🦺', '🐈‍⬛', '🐠', '🐦', '🐰', '🐹',
    
    // Row 21-22: Travel & Adventure (12)
    '✈️', '🗺️', '🧳', '🎒', '🚗', '🚙',
    '🏖️', '⛱️', '🏔️', '🗻', '🏕️', '⛺',
    
