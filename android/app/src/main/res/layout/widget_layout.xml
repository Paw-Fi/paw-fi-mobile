<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Setup View (Hidden by default) -->
    <LinearLayout
        android:id="@+id/widget_setup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:id="@+id/widget_setup_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_settings"
            android:alpha="0.5"
            app:tint="#6B7280" />

        <TextView
            android:id="@+id/widget_setup_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Long press to edit"
            android:textColor="#6B7280"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Main Content -->
    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_label_month"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THIS MONTH"
                    android:textColor="#88FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_total_spent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:id="@+id/widget_btn_settings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_settings"
                android:alpha="0.7"
                android:contentDescription="Settings" />

            <ImageView
                android:id="@+id/widget_btn_text"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/circle_background" 
                android:src="@drawable/ic_widget_text"
                android:padding="6dp"
                android:contentDescription="Add Expense" />
        </LinearLayout>

        <!-- Top Categories List -->
        <LinearLayout
            android:id="@+id/widget_pockets_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp">

            <!-- Item 1 -->
            <LinearLayout
                android:id="@+id/widget_item_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="4dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/widget_item_1_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Groceries"
                            android:textColor="#F1F5F9"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:singleLine="true" />
                         <TextView
                            android:id="@+id/widget_item_1_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$450"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/widget_item_1_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginTop="2dp"
                        android:progressDrawable="@drawable/custom_progress_bar"
                        android:max="100"
                        android:progress="60" />
                </LinearLayout>
            </LinearLayout>

            <!-- Item 2 -->
             <LinearLayout
                android:id="@+id/widget_item_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="4dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/widget_item_2_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Transport"
                            android:textColor="#F1F5F9"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:singleLine="true" />
                         <TextView
                            android:id="@+id/widget_item_2_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$120"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/widget_item_2_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginTop="2dp"
                        android:progressDrawable="@drawable/custom_progress_bar"
                        android:max="100"
                        android:progress="30" />
                </LinearLayout>
            </LinearLayout>

            <!-- Item 3 -->
             <LinearLayout
                android:id="@+id/widget_item_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="4dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/widget_item_3_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Dining"
                            android:textColor="#F1F5F9"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:singleLine="true" />
                         <TextView
                            android:id="@+id/widget_item_3_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$300"
                            android:textColor="#9CA3AF"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/widget_item_3_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginTop="2dp"
                        android:progressDrawable="@drawable/custom_progress_bar"
                        android:max="100"
                        android:progress="50" />
                </LinearLayout>
            </LinearLayout>
            
        </LinearLayout>

        <!-- Footer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_remaining"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Left: $0.00"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/widget_btn_camera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/pill_background"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp">

                <ImageView
                    android:id="@+id/widget_btn_camera_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_widget_camera"
                    app:tint="#7458FF" />

                <TextView
                    android:id="@+id/widget_btn_camera_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Scan"
                    android:textColor="#7458FF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
