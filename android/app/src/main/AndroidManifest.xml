<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Package visibility for URL intents (Android 11+) so url_launcher can resolve handlers -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="http" />
        </intent>
        <!-- Optional: direct WhatsApp deep links if used anywhere -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="whatsapp" />
        </intent>
    </queries>
    <!-- Android 13+ runtime notifications permission -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Microphone access for recording voice notes in the AI expense assistant -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Required for Supabase/auth and any network calls in release builds -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required for Google Play Billing (subscriptions / in-app purchases) -->
    <uses-permission android:name="com.android.vending.BILLING" />
    <!-- Helpful for connectivity checks and some libraries -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    
    <!-- App badge permissions for various Android launchers -->
    <!-- Samsung -->
    <uses-permission android:name="com.sec.android.provider.badge.permission.READ"/>
    <uses-permission android:name="com.sec.android.provider.badge.permission.WRITE"/>
    <!-- HTC -->
    <uses-permission android:name="com.htc.launcher.permission.READ_SETTINGS"/>
    <uses-permission android:name="com.htc.launcher.permission.UPDATE_SHORTCUT"/>
    <!-- Sony -->
    <uses-permission android:name="com.sonyericsson.home.permission.BROADCAST_BADGE"/>
    <uses-permission android:name="com.sonymobile.home.permission.PROVIDER_INSERT_BADGE"/>
    <!-- Apex -->
    <uses-permission android:name="com.anddoes.launcher.permission.UPDATE_COUNT"/>
    <!-- Solid -->
    <uses-permission android:name="com.majeur.launcher.permission.UPDATE_BADGE"/>
    <!-- Huawei -->
    <uses-permission android:name="com.huawei.android.launcher.permission.CHANGE_BADGE" />
    <uses-permission android:name="com.huawei.android.launcher.permission.READ_SETTINGS" />
    <uses-permission android:name="com.huawei.android.launcher.permission.WRITE_SETTINGS" />
    
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:label="Moneko"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name="com.plaid.internal.link.LinkActivity"
            android:exported="false"
            android:resizeableActivity="true"
            android:screenOrientation="unspecified"
            tools:replace="android:resizeableActivity,android:screenOrientation" />
        <!-- Default notification channel (used when FCM message has no channel_id) -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="@string/default_notification_channel_id" />
        <!-- Default small icon and color for FCM notifications (used when server does not specify) -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@mipmap/ic_launcher_monochrome" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_color" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Generic handler for all custom moneko:// links (aligns with iOS CFBundleURLSchemes) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="moneko"/>
            </intent-filter>
            <!-- Deep Link for payment callback -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="moneko" android:host="payment"/>
            </intent-filter>
            <!-- Deep Link for OAuth callback - Supabase standard pattern -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="io.supabase.moneko" android:host="login-callback"/>
            </intent-filter>
            <!-- Deep Link for WhatsApp verification -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="moneko" android:host="verify-whatsapp"/>
            </intent-filter>
            <!-- Custom Deep Link for Household Invitation -->
            <!-- Format: moneko://households/join?token=... -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="moneko" android:host="households" android:pathPrefix="/join"/>
            </intent-filter>
            <!-- Android App Links for Household Invitation (Universal Links) -->
            <!-- Format: https://moneko.io/invites/{token} -->
            <!-- Requires: .well-known/assetlinks.json on moneko.io -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https" android:host="moneko.io" android:pathPrefix="/invites"/>
                <data android:scheme="https" android:host="www.moneko.io" android:pathPrefix="/invites"/>
            </intent-filter>
        </activity>

        <!-- Native configuration Activity for the Moneko home screen widget.
             This is referenced from res/xml/widget_info.xml via android:configure
             so that long-press "Edit" and initial placement open the same
             configuration flow as the in-widget settings button. -->
        <activity
            android:name=".MonekoWidgetConfigureActivity"
            android:exported="true" />

        <!-- Temporarily disabled widget provider due to compilation errors
        <receiver android:name=".MonekoWidgetProvider" android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>
        -->
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
</manifest>
